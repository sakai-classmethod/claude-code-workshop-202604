{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-sonnet-4-6",
  "statusLine": {
    "type": "command",
    "command": ".claude/statusline.sh",
    "padding": 0
  },
  "permissions": {
    "allow": [
      "Bash(npm test:*)",
      "Bash(npm run build:*)"
    ],
    "ask": [
      "Bash(git push:*)"
    ],
    "deny": [
      "Edit(.env)",
      "Edit(.env.*)"
    ]
  }
}